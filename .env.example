# Postgres (matches infra/docker/docker-compose.yml)
DATABASE_URL="postgresql://apex:apex@localhost:5432/apex_ia"

# NextAuth
NEXTAUTH_SECRET="change-me-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Pont d'identité LibreChat (docs/IDENTITY_BRIDGE.md)
# DOIT être identique à JWT_SECRET dans apps/librechat/.env pour que apps/web
# puisse vérifier les tokens émis par LibreChat.
LIBRECHAT_JWT_SECRET="identique-au-JWT_SECRET-de-librechat"

# LLM provider (Anthropic) — utilisé par les modules apps/web hors chat.
# Le chat lui-même passe par LibreChat (apps/librechat/.env).
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-sonnet-4-6"
