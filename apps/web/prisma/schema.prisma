generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  /// Null pour les comptes liés via un provider externe (ex: LibreChat) — ils
  /// n'ont pas de mot de passe local. Voir docs/IDENTITY_BRIDGE.md.
  passwordHash  String?
  name          String?
  /// Source d'identité : "local" (email/mot de passe) ou "librechat" (pont SSO).
  provider      String         @default("local")
  /// Identifiant stable côté provider externe, ex: "librechat:<mongoId>". Unique.
  providerUserId String?       @unique
  createdAt     DateTime       @default(now())
  conversations Conversation[]
  resumes       Resume[]
  memories      Memory[]
}

model Conversation {
  id        String    @id @default(cuid())
  title     String    @default("Nouvelle conversation")
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  /// Routing metadata for assistant messages (audit / cost tracking). Empty for user messages.
  modelTier      String       @default("")
  modelId        String       @default("")
  reasoningLevel String       @default("")
  usageMode      String       @default("")
  createdAt      DateTime     @default(now())
}

model Resume {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   @default("Mon CV")
  /// Structured ResumeData (see packages/documents/src/resume/types.ts)
  data      Json
  locale    String   @default("fr")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Mémoire personnelle : préférences que l'IA retient (prénom, langue, style,
/// habitudes, objectifs...). L'utilisateur peut voir, modifier, supprimer,
/// désactiver (enabled=false, gardé mais non injecté au contexte) et exporter.
/// Voir docs/MEMORY.md.
model Memory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Catégorie : prenom, langue, style, habitudes, objectifs, projets, interets, besoins, general.
  category  String   @default("general")
  /// Clé lisible (ex: "Prénom", "Langue préférée").
  label     String
  value     String
  /// Désactivée = conservée mais non fournie à l'IA.
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}
